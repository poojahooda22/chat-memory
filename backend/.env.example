# copy this file to .env and fill in real values — .env is gitignored (this file is NOT)

# local Postgres from docker-compose.yml (host port 5434)
DATABASE_URL=postgresql+psycopg://chatmemory:chatmemory@localhost:5434/chatmemory

# Vercel AI Gateway key — https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=your-key-here

# models (paper-faithful defaults; override to swap providers, e.g. Ollama)
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# Supabase Auth — the backend needs ONLY the project URL (it verifies access-token JWTs against
# the public JWKS; no keys required). The anon key is a FRONTEND var (frontend/.env), and the
# service_role key is a full-admin secret this app does NOT use — never put either in this file.
SUPABASE_URL=https://szzvccfrnlhnyptouamj.supabase.co

# MCP server transport: stdio (default, local single-user via MCP_USER_ID) or streamable-http
# (remote multi-tenant — every request needs a Supabase bearer token; identity = token sub).
# MCP_TRANSPORT=streamable-http
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8010
# MCP_PUBLIC_URL=http://127.0.0.1:8010/mcp

# GitHub OAuth (the future GitHub connector) — REAL values go in .env only, never in this file
GITHUB_CLIENT_ID=your-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-oauth-app-client-secret